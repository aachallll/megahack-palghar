# Supabase credentials (use service role key, NOT anon key)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Groq AI API key (free at groq.com)
GROQ_API_KEY=your_groq_api_key

# Camera source
# 0 = default webcam
# 1, 2 = other connected cameras
# rtsp://user:pass@ip:port/stream = IP camera
CAMERA_SOURCE=0

# Model confidence threshold (0.0 to 1.0)
MODEL_CONFIDENCE=0.45

# Server config
PORT=8000
HOST=0.0.0.0

# Frontend URL for CORS (your Vercel URL in production)
FRONTEND_URL=http://localhost:8080